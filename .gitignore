# macOS junk
.DS_Store
**/.DS_Store

# Rolling auto-backups written by fine-tune/evals/scripts/apply-merge-candidate.py.
# Script overwrites on each apply; git history is the durable record.
fine-tune/evals/baseline.json.bak-*
fine-tune/evals/rule-registry.json.bak-*

# Per-fixture model-output directories written during a manual cross-model run.
# The canonical capture destination is fine-tune/evals/runs/<date>/<ide>-<model>/
# — those SHOULD be committed. Run-in-place .audit-run-* directories inside
# fixtures are scratch output and stay out of git.
fine-tune/evals/fixtures/**/.audit-run-*/
fine-tune/evals/fixtures/**/repo/.audit/

# Scratch PROPOSED-EDITS drafts that haven't been filed into evals/proposals/.
# Once a proposal is promoted to a merge candidate and captured in git log,
# the PROPOSED-EDITS-*.md draft is redundant.
PROPOSED-EDITS-*.md

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# Editor noise
.vscode/
.idea/
*.swp
*.swo
*~

# IDE-local state from non-Claude IDEs used during cross-model fixture runs
# (cursor, antigravity, cline, continue, windsurf, zed — add yours here).
# The *outputs* go under fine-tune/evals/runs/<date>/<ide>-<model>/ and ARE
# committed; only the IDE's local state files stay out.
.antigravity/
.cursor/
.cline/
.continue/
.windsurf/
.zed/
.vercel
.env*.local
